# Copy this file to .env and adjust as needed. Every variable has a
# corresponding Field(description=...) in config/settings.py — that is
# the canonical reference. Defaults shown match config/settings.py.

# --- API keys (required for the relevant providers; never commit real values) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- MediaWiki ---
WIKI_BASE_URL=https://hellokittyislandadventure.wiki.gg
WIKI_API_URL=https://hellokittyislandadventure.wiki.gg/api.php
# Sleep before every wiki request (and on retries) to respect rate limits.
WIKI_REQUEST_DELAY_SECONDS=0.75

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data
# Naming convention: hkia_{embedding_model}_{chunking_strategy}_v{n}.
# Bump v{n} when changing embedding_model or chunking_strategy — drift
# is detected at startup and raises EmbeddingModelMismatchError.
CHROMA_COLLECTION_NAME=hkia_nomic-embed-text_recursive_v2

# --- Embedding ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_MODEL_VERSION=v1.5
OPENAI_EMBEDDING_BATCH_SIZE=100

# --- LLM ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Per-request timeout for Ollama. Default suits small/medium models;
# raise for 70B+ where a single completion may exceed three minutes.
OLLAMA_REQUEST_TIMEOUT_SECONDS=180

# --- LangGraph agent ---
# Hard ceiling on the agent's retrieve→extract loop. Only guaranteed
# termination path on persistent JSON parse failures.
AGENT_MAX_ITERATIONS=10

# --- SQLite (per-page ingestion state) ---
STATE_DB_PATH=./data/ingestion_state.db

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=hkia_rag

# --- Chunking ---
# 'recursive' splits on paragraph/line/word boundaries.
# 'section' preserves wiki section headings as retrieval context.
# Changing this requires bumping CHROMA_COLLECTION_NAME and re-ingesting.
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
RETRIEVAL_TOP_K=5
# Reserved for future use; currently unused by semantic_search.
RETRIEVAL_SIMILARITY_THRESHOLD=0.7

# --- Retrieval logging (per-event JSONL) ---
# Disable when reducing on-disk PII surface (user questions are logged).
RETRIEVAL_LOG_ENABLED=true
RETRIEVAL_LOG_FILE=logs/retrieval.jsonl
